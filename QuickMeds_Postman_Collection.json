{
  "info": {
    "name": "QuickMeds API",
    "description": "Pharmacy Ordering System API - Complete REST API collection for testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/register",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Register a new user account"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@quickmeds.com\",\n  \"password\": \"user123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login and receive JWT token. Use the token in the 'Authorization' header as: Bearer <token>"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Medicines",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/medicines",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "medicines"
              ]
            },
            "description": "Retrieve all available medicines. Optional params: search (string), categoryId (number)"
          }
        },
        {
          "name": "Get Medicines with Filter",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/medicines?search=Paracetamol&categoryId=1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "medicines"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "Paracetamol"
                },
                {
                  "key": "categoryId",
                  "value": "1"
                }
              ]
            },
            "description": "Search and filter medicines by name and category"
          }
        },
        {
          "name": "Get Medicine by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/medicines/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "medicines",
                "1"
              ]
            },
            "description": "Get detailed information about a specific medicine"
          }
        },
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/categories",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "categories"
              ]
            },
            "description": "Retrieve all medicine categories"
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/cart",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "cart"
              ]
            },
            "description": "Get current user's shopping cart. Requires JWT authentication."
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"medicineId\": 1,\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/cart/items",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "cart",
                "items"
              ]
            },
            "description": "Add medicine to cart or increase quantity if already in cart"
          }
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 5\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/cart/items/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "cart",
                "items",
                "1"
              ]
            },
            "description": "Update quantity of a cart item (itemId in URL)"
          }
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/cart/items/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "cart",
                "items",
                "1"
              ]
            },
            "description": "Remove an item from the cart (itemId in URL)"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prescriptionId\": null\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/orders",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "orders"
              ]
            },
            "description": "Create an order from items in the cart. Cart items are copied to order and cart is cleared. prescriptionId is optional (null if not required)"
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/orders",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "orders"
              ]
            },
            "description": "Retrieve all orders placed by the current user"
          }
        }
      ]
    },
    {
      "name": "Prescriptions",
      "item": [
        {
          "name": "Upload Prescription",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "http://localhost:8080/api/prescriptions/upload",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "prescriptions",
                "upload"
              ]
            },
            "description": "Upload a prescription file. Use form-data with key 'file' for multipart upload."
          }
        },
        {
          "name": "Get My Prescriptions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/prescriptions",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "prescriptions"
              ]
            },
            "description": "Retrieve all prescriptions uploaded by the current user"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Create Medicine",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer ADMIN_JWT_TOKEN_HERE"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aspirin 500mg\",\n  \"description\": \"Pain relief and fever treatment\",\n  \"price\": 3.50,\n  \"stock\": 100,\n  \"prescriptionRequired\": false,\n  \"categoryId\": 1,\n  \"imageUrl\": \"https://example.com/aspirin.jpg\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/admin/medicines",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "admin",
                "medicines"
              ]
            },
            "description": "Create a new medicine (Admin only)"
          }
        },
        {
          "name": "Update Medicine",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer ADMIN_JWT_TOKEN_HERE"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aspirin 500mg Updated\",\n  \"description\": \"Updated description\",\n  \"price\": 3.99,\n  \"stock\": 150,\n  \"prescriptionRequired\": false,\n  \"categoryId\": 1,\n  \"imageUrl\": \"https://example.com/aspirin-updated.jpg\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/admin/medicines/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "admin",
                "medicines",
                "1"
              ]
            },
            "description": "Update an existing medicine (Admin only)"
          }
        },
        {
          "name": "Delete Medicine",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer ADMIN_JWT_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/admin/medicines/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "admin",
                "medicines",
                "1"
              ]
            },
            "description": "Delete a medicine (Admin only)"
          }
        },
        {
          "name": "Validate Prescription",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer ADMIN_JWT_TOKEN_HERE"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"validated\": true\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/admin/prescriptions/1/validate",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "admin",
                "prescriptions",
                "1",
                "validate"
              ]
            },
            "description": "Validate/approve a user's prescription (Admin only)"
          }
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ]
}
